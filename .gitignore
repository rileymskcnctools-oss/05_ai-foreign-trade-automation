# FT Workspace v2.0 — .gitignore

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/

# Database files (keep schema, not data)
data/*.db
data/*.db-wal
data/*.db-shm
data/backups/

# Environment / secrets
config/.env
*.env
*.key

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Excel lock files
~$*.xlsx
~$*.xls

# IDE
.vscode/
.idea/
*.swp
*.swo

# Output files (generated content, not tracked)
output/
*.pdf
*.docx
*.pptx

# Large assets
assets/images/*.png
assets/images/*.jpg
assets/images/*.jpeg

# Logs
*.log

# Archive
archive/
